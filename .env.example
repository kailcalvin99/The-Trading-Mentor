# =============================================================================
# The Trading Mentor — Root Environment Variables
# =============================================================================
# Copy the relevant sections to each service's own .env file,
# or set these as secrets in your hosting environment (e.g. Replit Secrets).
# NEVER commit a real .env file — only .env.example is tracked by git.
# =============================================================================

# --- Server ---
PORT=8080                           # Port the API server listens on
NODE_ENV=development                # "development" or "production"

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/trading_mentor
# PostgreSQL connection string used by both the API server and Drizzle ORM.

# --- Authentication ---
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars
# Used to sign JWT session tokens. Keep this secret and rotate it periodically.
# Alias: JWT_SECRET (either variable name is accepted)

# --- Admin ---
ADMIN_EMAIL=admin@example.com
# The email address that receives the admin role on first registration.

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Your Stripe Secret Key. Use a test key (sk_test_...) in development,
# live key (sk_live_...) in production.

# --- AI / Gemini (required — provision via Replit AI Integrations) ---
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here
# API key for Google Gemini AI. On Replit this is provisioned automatically
# via the Gemini AI integration (see .local/skills/ai-integrations-gemini).
# Outside Replit, supply your own Google AI Studio key.

AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Base URL for the Gemini API endpoint. On Replit this is overridden by the
# AI Integrations proxy. Outside Replit use the default Google endpoint above.

# --- Market Data ---
FINNHUB_API_KEY=your_finnhub_api_key_here
# Free key from https://finnhub.io — used for the economic calendar widget.

TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
# Free key from https://twelvedata.com — used for Chart Lab historical OHLCV data.

# --- Email / SMTP (Beta feedback notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=The Trading Mentor <noreply@example.com>
# If SMTP credentials are not set the app runs without email (graceful fallback).

# --- CORS ---
ALLOWED_ORIGINS=https://your-deployed-domain.com,https://www.your-deployed-domain.com
# Comma-separated list of origins allowed to call the API in production.
# In development, localhost and *.replit.dev are allowed automatically.

# --- Web App (Vite) ---
# These must be prefixed with VITE_ to be exposed to the browser bundle.
VITE_API_URL=/web/api
# Base path for API calls from the web frontend (relative to the proxy).

VITE_APP_URL=https://your-deployed-domain.com
# Absolute URL of the web app — used for Spotify OAuth redirect URIs.

VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Spotify application Client ID from https://developer.spotify.com/dashboard.
# This is a *public* client ID — safe to ship in client-side code.

VITE_SPOTIFY_REDIRECT_URI=https://your-deployed-domain.com/web/
# Must match a Redirect URI registered in your Spotify app dashboard.

# --- Mobile App (Expo) ---
EXPO_PUBLIC_DOMAIN=https://your-deployed-domain.com
# Base URL the Expo mobile app uses to reach the API server.

# --- Replit-injected (set automatically by Replit — do not set manually) ---
# REPL_ID                     Unique ID for the Replit workspace
# REPL_IDENTITY               Internal Replit identity token
# REPLIT_DEPLOYMENT           Set to "1" when running in a production deployment
# REPLIT_DEV_DOMAIN           The *.replit.dev subdomain for this workspace
# REPLIT_DOMAINS              Comma-separated list of public domains
# REPLIT_CONNECTORS_HOSTNAME  Hostname for the Replit Connectors service (Stripe integration)
# WEB_REPL_RENEWAL            Deployment renewal token (used by Stripe connector)
# BASE_PATH                   Artifact base path set by the artifact routing system
