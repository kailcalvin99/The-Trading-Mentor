# =============================================================================
# API Server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env — only .env.example is tracked by git.
# =============================================================================

# --- Server ---
PORT=8080
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/trading_mentor
# Full PostgreSQL connection string (pg / node-postgres format).
# Drizzle ORM and Stripe sync both read this variable.

# --- Authentication ---
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars
# Signs and verifies JWT tokens stored in httpOnly cookies.
# Also accepted as JWT_SECRET — only one needs to be set.

# --- Admin ---
ADMIN_EMAIL=admin@example.com
# The first user who registers with this email is granted the admin role.

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Stripe Secret Key. Use sk_test_... in development, sk_live_... in production.
# In Replit development the Stripe Connector fetches the key automatically;
# this variable is used as a fallback and is required in production deployments.

# --- AI / Gemini (required — provision via Replit AI Integrations) ---
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here
# API key for Google Gemini AI — powers the AI Mentor chat and analysis features.
# On Replit this is provisioned automatically via the Gemini AI integration.
# Outside Replit, supply your own key from https://aistudio.google.com/apikey

AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Base URL for the Gemini API. On Replit the AI Integrations proxy overrides this.
# Outside Replit, the default Google endpoint above is correct.

# --- Market Data ---
FINNHUB_API_KEY=your_finnhub_api_key_here
# Free tier available at https://finnhub.io
# Used by: /api/calendar (economic calendar widget)

TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
# Free tier available at https://twelvedata.com
# Used by: /api/replay (Chart Lab historical OHLCV candles)

# --- SMTP / Email ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=The Trading Mentor <noreply@example.com>
# Used to email beta feedback submissions to support@ictmentor.com.
# If any SMTP variable is missing the server starts normally but skips sending email.

# --- CORS ---
ALLOWED_ORIGINS=https://your-app-domain.com
# Comma-separated list of origins allowed in production.
# In development, localhost and *.replit.dev are permitted automatically.

# --- Mobile ---
EXPO_PUBLIC_DOMAIN=https://your-app-domain.com
# The base URL the Expo mobile app uses to reach this API server.

# --- Replit-injected (set automatically — do not set manually) ---
# REPL_ID                     Unique workspace ID
# REPL_IDENTITY               Replit identity token (used by Stripe Connector)
# REPLIT_DEPLOYMENT           "1" in production deployments
# REPLIT_DEV_DOMAIN           *.replit.dev subdomain for this workspace
# REPLIT_DOMAINS              Comma-separated public domain list
# REPLIT_CONNECTORS_HOSTNAME  Stripe Connector service hostname
# WEB_REPL_RENEWAL            Deployment renewal token (Stripe Connector fallback)
