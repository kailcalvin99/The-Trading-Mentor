# =============================================================================
# Mobile App (Expo/React Native) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env — only .env.example is tracked by git.
#
# All EXPO_PUBLIC_ variables are bundled into the app at build time.
# Do NOT put secrets here — only public configuration values.
# =============================================================================

# --- API Connection ---
EXPO_PUBLIC_DOMAIN=https://your-deployed-domain.com
# Base URL the mobile app uses to reach the API server.
# In local development on a real device this should be the full Replit
# dev domain URL (e.g. https://xxxx.replit.dev).
# In production this should be your deployed API server's URL.
