# =============================================================================
# Mobile App (Expo/React Native) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env — only .env.example is tracked by git.
#
# All EXPO_PUBLIC_ variables are bundled into the app at build time.
# Do NOT put secrets here — only public configuration values.
# =============================================================================

# --- API Connection ---
EXPO_PUBLIC_DOMAIN=your-deployed-domain.com
# Domain only — NO https:// prefix. The app prepends https:// automatically.
# Example development value: xxxx.replit.dev
# Example production value:  your-app.replit.app
# Used as: https://${EXPO_PUBLIC_DOMAIN}/api
