# =============================================================================
# Web App (Vite/React) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env — only .env.example is tracked by git.
#
# All VITE_ variables are bundled into the client-side JavaScript at build
# time. Do NOT put secrets here — only public configuration values.
# =============================================================================

# --- API Connection ---
VITE_API_URL=/web/api
# Base path for all API requests from the React frontend.
# In development this is proxied through Vite to the API server.
# In production this should match the path the API server is served on.

VITE_APP_URL=https://your-deployed-domain.com
# The absolute public URL of the web app.
# Used to construct OAuth redirect URIs (e.g. Spotify).

# --- Spotify Integration ---
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Your Spotify application's Client ID.
# Create an app at https://developer.spotify.com/dashboard to get one.
# This is a PUBLIC client ID — it is safe to expose in client-side code.

VITE_SPOTIFY_REDIRECT_URI=https://your-deployed-domain.com/web/
# The URI Spotify redirects to after OAuth authorisation.
# Must exactly match one of the Redirect URIs registered in your Spotify
# app dashboard. In local development use: http://localhost:22333/web/

# --- Replit-injected (set automatically — do not set manually) ---
# PORT         Port assigned by the Replit artifact routing system
# BASE_PATH    URL base path for this artifact (e.g. /web/)
# REPL_ID      Used by the Vite Cartographer plugin (dev-only)
